# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used to build the email confirmation redirect link in signup
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phone (OTP) sign-in/signup requires an SMS provider configured under
# Authentication -> Providers -> Phone in the Supabase dashboard
# (Twilio, MessageBird, Vonage, etc.) — no env var needed here, it's
# configured project-side.
